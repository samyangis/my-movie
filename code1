import React, { useState } from 'react';
import { Search, Globe2, Clapperboard, Star, LayoutGrid, List, ArrowUpRight } from 'lucide-react';
import { mockMovies } from './data/movies';

export default function App() {
  const [searchTerm, setSearchTerm] = useState('');
  const [activeFilter, setActiveFilter] = useState('All');
  const [viewMode, setViewMode] = useState('grid');

  const filteredMovies = mockMovies.filter(movie => {
    const searchLower = searchTerm.toLowerCase();
    const matchesSearch = movie.english_title.toLowerCase().includes(searchLower) ||
                          movie.original_title.toLowerCase().includes(searchLower);
    
    const matchesFilter = activeFilter === 'All' ||
      (activeFilter === '4K Ultra HD' && movie.streaming_4k.length > 0) ||
      (activeFilter === 'International' && !movie.origin_country.includes('US'));

    return matchesSearch && matchesFilter;
  });

  return (
    <div className="min-h-screen bg-[#0A0A0A] text-[#F5F5F7] font-sans antialiased selection:bg-neutral-800 selection:text-white">
      {/* Structural Glass Header */}
      <header className="sticky top-0 z-50 bg-[#0A0A0A]/70 backdrop-blur-xl border-b border-white/5">
        <div className="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
          <div className="flex items-center gap-3 group cursor-pointer">
            <Globe2 className="w-6 h-6 text-neutral-400 group-hover:text-white transition-colors duration-300" strokeWidth={1.5} />
            <span className="font-serif text-xl tracking-wide text-white">WorldCinema<span className="text-neutral-500 font-light">.</span></span>
          </div>

          <div className="flex items-center gap-8">
            <div className="relative">
              <input
                type="text"
                placeholder="Search cinematic works..."
                value={searchTerm}
                onChange={(e) => setSearchTerm(e.target.value)}
                className="bg-neutral-900/60 border border-white/5 rounded-full py-2 pl-10 pr-4 text-sm outline-none w-64 focus:border-white/20 focus:bg-neutral-900 transition-all duration-300 placeholder:text-neutral-600"
              />
              <Search className="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-600" />
            </div>
            <nav className="flex items-center gap-6 text-xs tracking-widest uppercase text-neutral-400 font-medium">
              <a href="#" className="hover:text-white transition-colors">Archive</a>
              <a href="#" className="hover:text-white transition-colors">Curated</a>
            </nav>
          </div>
        </div>
      </header>

      {/* Hero Showcase Frame */}
      <section className="relative h-[45vh] bg-black overflow-hidden border-b border-white/5">
        <div className="absolute inset-0 bg-gradient-to-t from-[#0A0A0A] via-transparent to-transparent z-10" />
        <div className="absolute inset-0 opacity-40 bg-cover bg-center" style={{ backgroundImage: `url(${mockMovies[0].backdrop_path})` }} />
        <div className="absolute bottom-12 left-0 w-full z-20">
          <div className="max-w-7xl mx-auto px-6">
            <span className="text-xs uppercase tracking-[0.2em] text-neutral-400 font-semibold">Featured Spotlight</span>
            <h2 className="font-serif text-5xl text-white mt-2 mb-1">{mockMovies[0].english_title}</h2>
            <p className="text-lg font-light text-neutral-400 tracking-wide font-serif italic">{mockMovies[0].original_title}</p>
          </div>
        </div>
      </section>

      {/* Control Console */}
      <main className="max-w-7xl mx-auto px-6 py-12">
        <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-6 mb-10">
          <div className="flex items-center gap-2 font-serif text-lg text-neutral-300">
            <span>Index Collection</span>
            <span className="font-sans text-xs bg-neutral-900 px-2 py-0.5 rounded text-neutral-500 border border-white/5">{filteredMovies.length}</span>
          </div>

          <div className="flex items-center gap-4">
            <div className="bg-neutral-900/40 p-1 rounded-full border border-white/5 flex gap-1 text-xs">
              {['All', '4K Ultra HD', 'International'].map(filter => (
                <button
                  key={filter}
                  onClick={() => setActiveFilter(filter)}
                  className={`px-4 py-1.5 rounded-full transition-all duration-200 ${activeFilter === filter ? 'bg-neutral-800 text-white shadow-sm' : 'text-neutral-500 hover:text-neutral-300'}`}
                >
                  {filter}
                </button>
              ))}
            </div>

            <div className="h-4 w-[1px] bg-white/10" />

            <div className="bg-neutral-900/40 p-1 rounded-full border border-white/5 flex gap-1">
              <button onClick={() => setViewMode('grid')} className={`p-1.5 rounded-full ${viewMode === 'grid' ? 'bg-neutral-800 text-white' : 'text-neutral-600'}`}>
                <LayoutGrid className="w-3.5 h-3.5" />
              </button>
              <button onClick={() => setViewMode('list')} className={`p-1.5 rounded-full ${viewMode === 'list' ? 'bg-neutral-800 text-white' : 'text-neutral-600'}`}>
                <List className="w-3.5 h-3.5" />
              </button>
            </div>
          </div>
        </div>

        {/* Master Render Pipeline */}
        {filteredMovies.length === 0 ? (
          <div className="py-24 text-center max-w-sm mx-auto space-y-3">
            <Clapperboard className="w-8 h-8 text-neutral-700 mx-auto" strokeWidth={1} />
            <h3 className="text-sm font-medium text-neutral-400">No titles match filters</h3>
            <p className="text-xs text-neutral-600">Try modifying your text search query or selected criteria module.</p>
          </div>
        ) : viewMode === 'grid' ? (
          <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
            {filteredMovies.map(movie => (
              <div key={movie.id} className="group cursor-pointer">
                <div className="relative aspect-[2/3] w-full bg-neutral-950 rounded-lg overflow-hidden border border-white/5 transition-all duration-300 group-hover:border-white/20 group-hover:scale-[1.01]">
                  <div className="absolute inset-0 bg-neutral-900 flex items-center justify-center text-xs text-neutral-700">Image Shell</div>
                  {movie.streaming_4k.length > 0 && (
                    <span className="absolute top-3 right-3 z-20 bg-neutral-900/90 text-neutral-300 text-[10px] font-medium tracking-widest px-2 py-0.5 rounded border border-white/10 backdrop-blur">4K UHD</span>
                  )}
                </div>
                <div className="mt-4 space-y-1">
                  <h4 className="text-sm font-medium text-white transition-colors group-hover:text-neutral-300 flex items-center justify-between">
                    {movie.english_title}
                    <span className="font-sans text-xs text-neutral-600 font-normal flex items-center gap-1"><Star className="w-3 h-3 text-neutral-500 fill-neutral-500" />{movie.vote_average}</span>
                  </h4>
                  <p className="font-serif text-xs text-neutral-500 italic">{movie.original_title}</p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div className="space-y-4">
            {filteredMovies.map(movie => (
              <div key={movie.id} className="bg-neutral-900/20 border border-white/5 p-6 rounded-xl flex items-center justify-between gap-8 hover:bg-neutral-900/40 transition-colors">
                <div className="space-y-2">
                  <div className="flex items-center gap-3">
                    <h3 className="text-base font-medium text-white">{movie.english_title}</h3>
                    <span className="font-serif text-xs text-neutral-500 italic">({movie.original_title})</span>
                  </div>
                  <p className="text-xs text-neutral-400 max-w-xl line-clamp-2 leading-relaxed">{movie.overview}</p>
                </div>
                <div className="flex flex-wrap gap-2 justify-end max-w-xs">
                  {movie.streaming_4k.map(platform => (
                    <a
                      key={platform.provider}
                      href={platform.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      className="bg-neutral-900 border border-white/5 text-xs text-neutral-300 px-3 py-1.5 rounded-md hover:bg-white hover:text-black transition-all flex items-center gap-1.5 font-medium shadow-sm"
                    >
                      {platform.provider} <ArrowUpRight className="w-3 h-3 opacity-60" />
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}
      </main>
    </div>
  );
}
